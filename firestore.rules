rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Auth Helpers
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isPlatformOwner() {
      return isAuthenticated() && (
        (request.auth.token.email == "michaelmitry13@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/global_users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data.role == 'platform_owner')
      );
    }

    // ===============================================================
    // Tenant-Level Auth Helpers
    // ===============================================================

    function isTenantMember(tenantId) {
      return isAuthenticated() && (
        isPlatformOwner() ||
        exists(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid))
      );
    }

    // Scope check helper to fetch data role dynamically
    function getTenantRole(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid)).data.role;
    }

    function isTenantAdmin(tenantId) {
      return isAuthenticated() && (
        isPlatformOwner() ||
        (isTenantMember(tenantId) && getTenantRole(tenantId) in ['admin', 'manager', 'super_admin', 'crm_admin'])
      );
    }

    // Checks super user status inside the tenant
    function isTenantSuperAdmin(tenantId) {
      return isAuthenticated() && (
        isPlatformOwner() ||
        (isTenantMember(tenantId) && getTenantRole(tenantId) in ['super_admin', 'crm_admin'])
      );
    }

    function isTenantRep(tenantId) {
      return isAuthenticated() && isTenantMember(tenantId) && getTenantRole(tenantId) == 'rep';
    }

    // ===============================================================
    // Strike CRM Root Auth Helpers
    // ===============================================================

    function userExists() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStrikeAdmin() {
      return isAuthenticated() && (
        request.auth.token.email in [
          "michaelmitry13@gmail.com",
          "magd.gallab@gmail.com",
          "admin@strike.eg",
          "strike.egyptt@gmail.com",
          "shadyyoussef305@gmail.com",
          "atefstrike@gmail.com"
        ] ||
        (userExists() && getUserRole() in ['admin', 'manager', 'super_admin', 'crm_admin'])
      );
    }

    function isStrikeSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email in [
          "michaelmitry13@gmail.com",
          "magd.gallab@gmail.com",
          "admin@strike.eg",
          "strike.egyptt@gmail.com",
          "shadyyoussef305@gmail.com",
          "atefstrike@gmail.com"
        ] ||
        (userExists() && getUserRole() in ['super_admin', 'crm_admin'])
      );
    }

    // ===============================================================
    // Field-Level Helpers
    // ===============================================================

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isNonEmptyString(val) {
      return val is string && val.size() > 0;
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= min &&
             request.resource.data[field].size() <= max;
    }

    function isPositiveNumber(val) {
      return val is number && val >= 0;
    }

    // ===============================================================
    // Entity Validators
    // ===============================================================

    function isValidRole(role) {
      return role in ['rep', 'manager', 'admin', 'super_admin', 'crm_admin'];
    }

    function isSafeUserSelfEdit() {
      let allowed = ['name', 'email', 'lastSeen', 'mustChangePassword', 'photoURL'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    function isValidUserWrite(data) {
      return isNonEmptyString(data.name) && data.name.size() >= 2 &&
             isNonEmptyString(data.email) && data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             isValidRole(data.role);
    }

    function isValidClient(data) {
      return isNonEmptyString(data.name) && data.name.size() >= 2 &&
             isNonEmptyString(data.phone) && data.phone.size() >= 7 &&
             data.status in ['Lead', 'Active', 'Nearly Expired', 'Expired', 'Hold'];
    }

    function isValidPaymentCreate(data) {
      return isNonEmptyString(data.clientId) &&
             isNonEmptyString(data.client_name) &&
             isNonEmptyString(data.sales_rep_id) &&
             isNonEmptyString(data.created_at) &&
             data.amount is number && data.amount > 0 &&
             data.amount_paid is number && data.amount_paid >= 0 &&
             isNonEmptyString(data.packageType) &&
             data.package_category_type in ['Private Training', 'Group Training'] &&
             data.method in ['Cash', 'Credit Card', 'Bank Transfer', 'Instapay', 'Other'] &&
             (!('instapayRef' in data) || (data.instapayRef is string && data.instapayRef.matches('^[0-9]{12}$')));
    }

    function paymentImmutableFieldsUnchanged() {
      let immutable = ['clientId', 'client_name', 'amount', 'sales_rep_id', 'created_at', 'package_category_type'];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(immutable);
    }

    function isValidSession(data) {
      return isNonEmptyString(data.clientId) &&
             data.status in ['Scheduled', 'Attended', 'No Show', 'Cancelled'];
    }

    function isValidInteraction(data) {
      return isNonEmptyString(data.date) &&
             data.type in ['Call', 'WhatsApp', 'Email', 'Visit'] &&
             data.outcome in ['Interested', 'Not Answered', 'Scheduled Trial', 'Rejected', 'Other'] &&
             isNonEmptyString(data.author);
    }

    function isValidAttendance(data) {
      return isNonEmptyString(data.clientId) &&
             isNonEmptyString(data.branch) &&
             isNonEmptyString(data.date) &&
             isNonEmptyString(data.recordedBy);
    }

    function isValidTask(data) {
      return isNonEmptyString(data.title) &&
             isNonEmptyString(data.dueDate) &&
             data.status in ['Pending', 'In Progress', 'Completed'] &&
             data.priority in ['Low', 'Medium', 'High'] &&
             isNonEmptyString(data.assignedTo) &&
             isNonEmptyString(data.createdBy) &&
             isNonEmptyString(data.createdAt);
    }

    function isTaskCreator() {
      return isAuthenticated() &&
             resource != null &&
             resource.data.createdBy == request.auth.uid;
    }

    function isValidPackage(data) {
      return isNonEmptyString(data.name) &&
             data.price is number && data.price >= 0 &&
             data.sessions is number && data.sessions >= 0 &&
             data.expiryDays is number && data.expiryDays >= 0 &&
             data.type in ['Private', 'Group', 'Other'];
    }

    // Coach status validation helper
    function isValidCoach(data) {
      return isNonEmptyString(data.name) &&
             data.active is bool;
    }

    function isValidTarget(data) {
      return isNonEmptyString(data.userId) &&
             data.targetAmount is number && data.targetAmount >= 0 &&
             isNonEmptyString(data.month) &&
             data.month.matches('^[0-9]{4}-[0-9]{2}$');
    }

    function isValidAuditLog(data) {
      return isNonEmptyString(data.userId) &&
             data.action in ['CREATE', 'UPDATE', 'DELETE'] &&
             data.entityType in ['CLIENT', 'PAYMENT', 'PACKAGE_RECORD', 'LEAD',
                                 'TARGET', 'ATTENDANCE', 'COACH', 'SYSTEM', 'BRANCH', 'SESSION'] &&
             isNonEmptyString(data.entityId) &&
             isNonEmptyString(data.timestamp);
    }

    function isValidBranding(data) {
      return data.keys().hasAny(['companyName', 'logoUrl', 'kioskPin', 'dailyCheckinPin']) &&
             (!('companyName' in data) || isNonEmptyString(data.companyName)) &&
             (!('logoUrl' in data) || data.logoUrl is string);
    }

    // ===============================================================
    // Global Platform Collections
    // ===============================================================
    
    match /global_users/{userId} {
      allow read: if isPlatformOwner() || isOwner(userId);
      allow write: if isPlatformOwner();
    }

    // ===============================================================
    // Collection Group Rules (subcollections across all tenants)
    // ===============================================================

    match /{path=**}/comments/{commentId} {
      allow read: if isAuthenticated();
    }

    match /{path=**}/interactions/{interactionId} {
      allow read: if isAuthenticated();
    }

    match /{path=**}/attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidAttendance(request.resource.data);
    }

    // ===============================================================
    // Tenant Structure (Multi-Tenant SaaS, e.g., ATPLVECTOR)
    // ===============================================================

    match /tenants/{tenantId} {
      
      // The tenant record itself
      allow read: if isTenantMember(tenantId);
      allow write: if isPlatformOwner();

      // --- Users ---
      match /users/{userId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantSuperAdmin(tenantId) || isOwner(userId);
        allow update: if (isOwner(userId) && isSafeUserSelfEdit()) || isTenantAdmin(tenantId);
        allow delete: if isTenantSuperAdmin(tenantId);
      }

      // --- Clients ---
      match /clients/{clientId} {
        allow read: if isTenantMember(tenantId);
        allow create, update: if isTenantMember(tenantId) && isValidClient(request.resource.data);
        allow delete: if isTenantAdmin(tenantId);

        match /comments/{commentId} {
          allow read, create: if isTenantMember(tenantId);
          allow update, delete: if isTenantAdmin(tenantId);
        }

        match /interactions/{interactionId} {
          allow read: if isTenantMember(tenantId);
          allow create, update: if isTenantMember(tenantId) && isValidInteraction(request.resource.data);
          allow delete: if isTenantAdmin(tenantId);
        }
      }

      // --- Payments ---
      match /payments/{paymentId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId) && isValidPaymentCreate(request.resource.data);
        allow update: if isTenantAdmin(tenantId) && paymentImmutableFieldsUnchanged();
        allow delete: if isTenantSuperAdmin(tenantId);
      }

      // --- Sessions ---
      match /sessions/{sessionId} {
        allow read: if isTenantMember(tenantId);
        allow create, update: if isTenantMember(tenantId) && isValidSession(request.resource.data);
        allow delete: if isTenantAdmin(tenantId);
      }

      // --- Tasks ---
      match /tasks/{taskId} {
        allow read: if isTenantMember(tenantId);
        allow create, update: if isTenantMember(tenantId) && isValidTask(request.resource.data);
        allow delete: if isTenantAdmin(tenantId) || isTaskCreator();
      }

      // --- Packages ---
      match /packages/{packageId} {
        allow read: if isTenantMember(tenantId);
        allow create, update: if isTenantAdmin(tenantId) && isValidPackage(request.resource.data);
        allow delete: if isTenantAdmin(tenantId);
      }

      // --- Coaches ---
      match /coaches/{coachId} {
        allow read: if isTenantMember(tenantId);
        allow create, update: if isTenantAdmin(tenantId) && isValidCoach(request.resource.data);
        allow delete: if isTenantAdmin(tenantId);
      }

      // --- Targets ---
      match /targets/{targetId} {
        allow read: if isTenantMember(tenantId);
        allow create, update: if isTenantAdmin(tenantId) && isValidTarget(request.resource.data);
        allow delete: if isTenantAdmin(tenantId);
      }

      // --- Audit Logs ---
      match /auditLogs/{logId} {
        allow read: if isTenantAdmin(tenantId);
        allow create: if isTenantMember(tenantId) && isValidAuditLog(request.resource.data);
        allow update: if false;
        allow delete: if isTenantSuperAdmin(tenantId);
      }

      // --- Settings ---
      match /settings/{settingId} {
        allow read: if settingId == 'branding' ? true : isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId) && (settingId != 'branding' || isValidBranding(request.resource.data));
      }

      // --- Pending Accounts ---
      match /pendingAccounts/{docId} {
        allow read, write: if isTenantAdmin(tenantId) || isPlatformOwner();
        allow create: if isAuthenticated();
      }

      // --- Password Reset Requests ---
      match /passwordResetRequests/{docId} {
        allow read, write: if isTenantAdmin(tenantId) || isPlatformOwner();
        allow create: if isAuthenticated();
      }

      // --- Import Batches ---
      match /importBatches/{batchId} {
        allow read: if isTenantMember(tenantId);
        allow write, delete: if isTenantAdmin(tenantId);
      }

      // --- Counters ---
      match /counters/{counterId} {
        allow read: if isTenantMember(tenantId);
        allow write: if counterId == 'clients' ? isTenantMember(tenantId) : isTenantAdmin(tenantId);
      }
    }
    
    // ===============================================================
    // Strike CRM Root Collections (Single-Tenant Flat Structure)
    // ===============================================================

    // --- Root users ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isStrikeSuperAdmin() || isOwner(userId);
      allow update: if (isOwner(userId) && isSafeUserSelfEdit()) || isStrikeAdmin();
      allow delete: if isStrikeSuperAdmin();
    }

    // --- Root settings (branding, global config) ---
    match /settings/{settingId} {
      allow read: if settingId == 'branding' || isAuthenticated();
      allow write: if isStrikeAdmin() && (settingId != 'branding' || isValidBranding(request.resource.data));
    }

    // --- Root clients ---
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidClient(request.resource.data);
      allow update: if isAuthenticated() && isValidClient(request.resource.data);
      allow delete: if isStrikeAdmin();

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isStrikeAdmin();
      }

      match /interactions/{interactionId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidInteraction(request.resource.data);
        allow update: if isAuthenticated() && isValidInteraction(request.resource.data);
        allow delete: if isStrikeAdmin();
      }
    }

    // --- Root payments ---
    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPaymentCreate(request.resource.data);
      allow update: if isStrikeAdmin() && paymentImmutableFieldsUnchanged();
      allow delete: if isStrikeSuperAdmin();
    }

    // --- Root sessions (PT package records) ---
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidSession(request.resource.data);
      allow delete: if isStrikeAdmin();
    }

    // --- Root tasks ---
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && isValidTask(request.resource.data);
      allow delete: if isStrikeAdmin() || isTaskCreator();
    }

    // --- Root packages ---
    match /packages/{packageId} {
      allow read: if isAuthenticated();
      allow create, update: if isStrikeAdmin() && isValidPackage(request.resource.data);
      allow delete: if isStrikeAdmin();
    }

    // --- Root coaches ---
    match /coaches/{coachId} {
      allow read: if isAuthenticated();
      allow create, update: if isStrikeAdmin() && isValidCoach(request.resource.data);
      allow delete: if isStrikeAdmin();
    }

    // --- Root targets (sales targets) ---
    match /targets/{targetId} {
      allow read: if isAuthenticated();
      allow create, update: if isStrikeAdmin() && isValidTarget(request.resource.data);
      allow delete: if isStrikeAdmin();
    }

    // --- Root audit logs ---
    match /auditLogs/{logId} {
      allow read: if isStrikeAdmin();
      allow create: if isAuthenticated() && isValidAuditLog(request.resource.data);
      allow update: if false;
      allow delete: if isStrikeSuperAdmin();
    }

    // --- Root pending accounts (sign-up requests) ---
    match /pendingAccounts/{docId} {
      allow create: if true;
      allow read, update, delete: if isStrikeAdmin();
    }

    // --- Root password reset requests ---
    match /passwordResetRequests/{docId} {
      allow create: if true;
      allow read, update, delete: if isStrikeAdmin();
    }

    // --- Root import batches ---
    match /importBatches/{batchId} {
      allow read: if isAuthenticated();
      allow write, delete: if isStrikeAdmin();
    }

    // --- Root counters (sequential member IDs) ---
    match /counters/{counterId} {
      allow read: if isAuthenticated();
      allow write: if counterId == 'clients' ? isAuthenticated() : isStrikeAdmin();
    }

    // ===============================================================
    // Platform Fallback / Super Admin Bypass
    // ===============================================================
    match /{document=**} {
      allow read, write: if isPlatformOwner();
    }
  }
}
